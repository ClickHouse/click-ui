{
  "name": "@clickhouse/click-ui",
  "version": "0.0.235-sc-deprecation.1",
  "description": "Official ClickHouse design system react library",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "./dist/style.css",
    "./src/theme/global.scss"
  ],
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "click-ui": "./bin/click-ui.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/click-ui.es.js",
      "require": "./dist/click-ui.umd.js"
    },
    "./bundled": {
      "types": "./dist/index.d.ts",
      "import": "./dist/click-ui.bundled.es.js",
      "require": "./dist/click-ui.bundled.umd.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.js"
    },
    "./config/vite": {
      "types": "./dist/config/vite.d.ts",
      "import": "./dist/config/vite.js"
    },
    "./config/webpack": {
      "types": "./dist/config/webpack.d.ts",
      "import": "./dist/config/webpack.js"
    },
    "./config/rollup": {
      "types": "./dist/config/rollup.d.ts",
      "import": "./dist/config/rollup.js"
    },
    "./config/next": {
      "types": "./dist/config/next.d.ts",
      "import": "./dist/config/next.js"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/click-ui.umd.js",
  "module": "./dist/click-ui.es.js",
  "types": "./dist/index.d.ts",
  "keywords": [
    "click-ui",
    "clickhouse",
    "design system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ClickHouse/click-ui.git"
  },
  "homepage": "https://clickhouse.com",
  "scripts": {
    "build": "tsc && npm run build:config && vite build && npm run build:bundled",
    "build:bundled": "vite build -- bundled",
    "build:config": "tsc --project tsconfig.config.json",
    "build-storybook": "storybook build",
    "build:watch": "watch 'npm run build' ./src",
    "chromatic": "npx chromatic",
    "dev": "vite",
    "generate-tokens": "node build-tokens.js",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prettify": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\" --config .prettierrc",
    "prettier:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\" --config .prettierrc",
    "preview": "vite preview",
    "publish:click-ui": "npm run test && npm run build && npm publish",
    "storybook": "storybook dev -p 6006",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "watch": "vitest --watch"
  },
  "dependencies": {
    "@h6s/calendar": "^2.0.1",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dismissable-layer": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-popper": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-switch": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "clsx": "^2.1.1",
    "react-sortablejs": "^6.1.4",
    "react-syntax-highlighter": "^15.5.0",
    "react-virtualized-auto-sizer": "^1.0.20",
    "react-window": "^1.8.9",
    "sortablejs": "^1.15.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^9.0.18",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/addon-links": "^9.0.18",
    "@storybook/react-vite": "^9.0.18",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@tokens-studio/sd-transforms": "^0.10.3",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/react-window": "^1.8.8",
    "@types/sortablejs": "^1.15.2",
    "@types/webpack": "^5.28.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitejs/plugin-react": "^4.2.1",
    "chromatic": "^6.18.2",
    "eslint": "^8.57.0",
    "eslint-plugin-prefer-arrow-functions": "^3.3.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-storybook": "^9.0.18",
    "jsdom": "^24.0.0",
    "next": "^15.5.5",
    "prettier": "^3.6.2",
    "rollup": "^4.52.4",
    "sass-embedded": "^1.93.0",
    "storybook": "^9.0.18",
    "storybook-addon-pseudo-states": "^9.0.18",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.3",
    "vite": "^5.2.11",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^2.0.3",
    "watch": "^1.0.2",
    "webpack": "^5.102.1"
  },
  "peerDependencies": {
    "dayjs": "^1.11.18",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "dayjs": {
      "optional": true
    }
  }
}
