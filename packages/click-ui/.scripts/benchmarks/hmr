  await fs.writeFile(
    path.join(PLAYGROUND_DIR, 'tsconfig.json'),
    JSON.stringify(tsConfig, null, 2)
  );

  await fs.mkdir(path.join(PLAYGROUND_DIR, 'src'), { recursive: true });

  // Vite config will be written per-test by writeViteConfig
  console.log('[OK] Playground structure created\n');
