const __dirname = path.dirname(__filename);

const PATH_TO_ROOT = ['..', '..'];
const PLAYGROUND_PATH_TO_ROOT = '../../..';

const ROOT_DIR = path.resolve(__dirname, ...PATH_TO_ROOT);
const PLAYGROUND_DIR = path.join(__dirname, 'playground');

const MODIFICATION_MARKER = '// HMR_TEST_MARKER_';

