async function installDependencies() {
  console.log('[INSTALL] Installing dependencies...');

  return new Promise((resolve, reject) => {
    const child = spawn('npm', ['install'], {
      cwd: PLAYGROUND_DIR,
      stdio: 'pipe',
    });

    child.on('close', code => {
      if (code === 0) {
        console.log('[OK] Dependencies installed\n');
        resolve();
      } else {
        reject(new Error(`npm install exited with code ${code}`));
      }
    });
  });
}

async function writeAppFile(config) {
  await fs.writeFile(path.join(PLAYGROUND_DIR, 'src', 'main.tsx'), config.getCode());
}

async function writeViteConfig() {
  // Symlink approach: Only use @ alias for internal imports
  // @clickhouse/click-ui/* will resolve through node_modules symlink + package.json exports
  const rootPath = PLAYGROUND_PATH_TO_ROOT;
  const viteConfig = `import { defineConfig } from 'vite'
import react from '@vitejs/plugin-react'
import path from 'path'
import tsconfigPaths from 'vite-tsconfig-paths'

const ROOT_PATH = '${rootPath}'
const parentSrcDir = path.resolve(__dirname, ROOT_PATH, 'src')

export default defineConfig({
  plugins: [
    react(),
    tsconfigPaths({
      projects: [path.resolve(__dirname, ROOT_PATH, 'tsconfig.json')]
    }),
    {
      name: 'watch-external-src',
      configureServer(server) {
        server.watcher.add(parentSrcDir)
      }
    }
  ],
  resolve: {
    alias: {
      '@': path.resolve(__dirname, ROOT_PATH, 'src'),
    }
  },
  server: {
    open: false,
    port: 5174,
    hmr: true,
    fs: {
      allow: ['..', ROOT_PATH, \`\${ROOT_PATH}/src\`, \`\${ROOT_PATH}/node_modules/@clickhouse\`]
    },
    watch: {
      usePolling: true,
      interval: 100
    }
  },
  optimizeDeps: {
    include: ['react', 'react-dom', 'styled-components'],
    exclude: ['@clickhouse/click-ui']
  }
})
`;
  await fs.writeFile(path.join(PLAYGROUND_DIR, 'vite.config.ts'), viteConfig);
}

async function backupOriginalFile(filePath) {
  if (!originalContents.has(filePath)) {
    const content = await fs.readFile(filePath, 'utf-8');
    originalContents.set(filePath, content);
  }
}

async function restoreOriginalFiles() {
  console.log('\n[RESTORE] Restoring original source files...');

  for (const [filePath, content] of originalContents) {
    try {
      await fs.writeFile(filePath, content);
      console.log(`  [OK] Restored: ${path.relative(ROOT_DIR, filePath)}`);
    } catch (err) {
      console.warn(`  [WARN] Failed to restore: ${path.relative(ROOT_DIR, filePath)}`);
    }
  }

  originalContents.clear();
}

async function modifySourceFile(filePath, iteration) {
  await backupOriginalFile(filePath);

  let content = await fs.readFile(filePath, 'utf-8');
  const lines = content.split('\n');
  const cleanedLines = lines.filter(line => !line.includes(MODIFICATION_MARKER));
  cleanedLines.push(`${MODIFICATION_MARKER}${iteration}`);

  await fs.writeFile(filePath, cleanedLines.join('\n'));

  console.log(`  [MODIFY] ${path.relative(ROOT_DIR, filePath)} (marker: ${iteration})`);
}

async function clearViteCache() {
  const cachesToClear = [
    path.join(PLAYGROUND_DIR, 'node_modules', '.vite'),
    path.join(ROOT_DIR, 'node_modules', '.vite'),
  ];

  for (const cachePath of cachesToClear) {
    try {
      await fs.rm(cachePath, { recursive: true, force: true });
    } catch (err) {
      // Cache might not exist
    }
  }
}

// Strip ANSI escape codes from text
function stripAnsi(text) {
  // eslint-disable-next-line no-control-regex
  return text.replace(/\x1B\[[0-9;]*[mGKH]/g, '');
}

function startDevServer() {
  return new Promise((resolve, reject) => {
    const child = spawn('npm', ['run', 'dev'], {
      cwd: PLAYGROUND_DIR,
      stdio: 'pipe',
      env: {
        ...process.env,
        FORCE_COLOR: '0',
        NO_COLOR: '1',
        DEBUG: 'vite:hmr',
      },
    });

    let isReady = false;
    const timeout = setTimeout(() => {
      child.kill('SIGTERM');
      reject(new Error('Dev server startup timeout (60s)'));
    }, 60000);

    child.stdout.on('data', data => {
      const output = data.toString();

      if (
        !isReady &&
        (output.includes('ready') || output.includes('5174') || output.includes('Local:'))
      ) {
        isReady = true;
        clearTimeout(timeout);
        resolve(child);
      }
    });

    child.stderr.on('data', data => {
      const output = data.toString();
      if (output.toLowerCase().includes('fatal') && !isReady) {
        clearTimeout(timeout);
        child.kill('SIGTERM');
        reject(new Error(`Dev server error: ${output.substring(0, 200)}`));
      }
    });

    child.on('error', reject);
    child.on('close', code => {
      if (!isReady) {
        reject(new Error(`Dev server exited with code ${code}`));
      }
    });
  });
}

// Preload modules by making HTTP requests to Vite
async function preloadModules() {
  try {
    await fetch('http://localhost:5174/');
    await fetch('http://localhost:5174/src/main.tsx');
    console.log('  [OK] Modules preloaded');
  } catch (e) {
    console.log('  [WARN] Module preload warning:', e.message);
  }
}

async function measureHMR(devServer, targetFile, iteration) {
  return new Promise(resolve => {
    const startTime = Date.now();
    let hmrTime = null;
    let detectedType = null;
    const debugOutput = [];
    let fileChangeDetected = false;

    const timeout = setTimeout(() => {
      cleanup();
      console.log(`  [WARN] Debug output (last 10 lines):`);
      debugOutput
        .slice(-10)
        .forEach(line => console.log(`    > ${line.substring(0, 100)}`));
      resolve({
        success: false,
        error: fileChangeDetected
          ? 'HMR timeout (5s) - file change detected but no HMR/reload completed'
          : 'HMR timeout (5s) - file change not detected by Vite',
      });
    }, 5000);

    const cleanup = () => {
      clearTimeout(timeout);
      devServer.stdout.removeListener('data', onData);
      devServer.stderr.removeListener('data', onError);
    };

    const checkForHmrCompletion = rawOutput => {
      if (hmrTime) return false;

      const output = stripAnsi(rawOutput);

      // Vite stdout: "[vite] (client) hmr update /path/to/file"
      if (output.match(/\(client\)\s*hmr\s+update/i)) {
        hmrTime = Date.now() - startTime;
        detectedType = 'HMR update';
        cleanup();
        resolve({ success: true, hmrTime, type: detectedType });
        return true;
      }

      // Vite stdout: "[vite] (client) page reload /path/to/file"
      if (output.match(/\(client\)\s*page\s*reload/i)) {
        hmrTime = Date.now() - startTime;
        detectedType = 'Page reload';
        cleanup();
        resolve({ success: true, hmrTime, type: detectedType });
        return true;
      }

      // Vite debug stderr: "vite:hmr [file change]"
      if (output.match(/vite:hmr.*\[file\s+change\]/i)) {
        if (!fileChangeDetected) {
          fileChangeDetected = true;
          console.log(`  [INFO] File change detected by Vite...`);
        }
      }

      return false;
    };

    const onData = data => {
      const output = data.toString();
      const lines = output.split('\n').filter(l => l.trim());
      lines.forEach(line => {
        if (line.trim()) debugOutput.push(stripAnsi(line.trim()));
      });
      if (debugOutput.length > 50) debugOutput.splice(0, debugOutput.length - 50);

      if (checkForHmrCompletion(output)) return;
    };

    const onError = data => {
      const output = data.toString();
      const lines = output.split('\n').filter(l => l.trim());
      lines.forEach(line => {
        if (line.trim()) debugOutput.push('ERR: ' + stripAnsi(line.trim()));
      });

      if (checkForHmrCompletion(output)) return;
    };

    devServer.stdout.on('data', onData);
    devServer.stderr.on('data', onError);

    setTimeout(() => {
      modifySourceFile(targetFile, iteration).catch(err => {
        cleanup();
        resolve({ success: false, error: `Failed to modify file: ${err.message}` });
      });
    }, 100);
  });
}

async function runBenchmarkWithServer(config) {
  console.log(`\n[BENCHMARK] ${config.name}`);
  console.log(`   ${config.description}`);

  await writeViteConfig();
  await writeAppFile(config);
  await clearViteCache();

  console.log('  [START] Starting dev server...');
  let devServer;

  try {
    devServer = await startDevServer();
    console.log('  [OK] Dev server ready');
  } catch (error) {
    console.log(`  [FAIL] Failed to start dev server: ${error.message}`);
    return null;
  }

  const results = [];
  const hmrTypes = [];
  // count
  const iterations = 100;

  await new Promise(r => setTimeout(r, 2000));
  await preloadModules();
  await new Promise(r => setTimeout(r, 1000));

  try {
    for (let i = 1; i <= iterations; i++) {
      console.log(`  [TEST] HMR test ${i}/${iterations}`);

      const result = await measureHMR(devServer, config.targetFile, i);

      if (result.success) {
        results.push(result.hmrTime);
        hmrTypes.push(result.type || 'HMR');
        console.log(`  [OK] ${result.type || 'HMR'} time: ${result.hmrTime}ms`);
      } else {
        console.log(`  [FAIL] HMR failed: ${result.error}`);
      }

      // if (i < iterations) {
      //   await new Promise(r => setTimeout(r, 1000));
      // }
    }
  } finally {
    console.log('  [STOP] Stopping dev server...');
    devServer.kill('SIGTERM');
    await new Promise(r => setTimeout(r, 1000));
  }

  if (results.length === 0) {
    return null;
  }

  const avg = Math.round(results.reduce((a, b) => a + b, 0) / results.length);
  const min = Math.min(...results);
  const max = Math.max(...results);
  const median = results.sort((a, b) => a - b)[Math.floor(results.length / 2)];

  const typeCounts = {};
  hmrTypes.forEach(t => (typeCounts[t] = (typeCounts[t] || 0) + 1));
  const predominantType =
    Object.entries(typeCounts).sort(([, a], [, b]) => b - a)[0]?.[0] || 'unknown';

  return {
    name: config.name,
    description: config.description,
    avgTime: avg,
    minTime: min,
    maxTime: max,
    medianTime: median,
    hmrType: predominantType,
    results,
  };
}

function printResults(results) {
  console.log('\n' + '='.repeat(90));
  console.log('HMR (HOT MODULE REPLACEMENT) BENCHMARK RESULTS');
  console.log('   Measuring reload speed when modifying source files');
  console.log('='.repeat(90));

  console.log('\n' + '-'.repeat(90));
  console.log(
    `${'Configuration'.padEnd(35)} | ` +
      `${'Avg'.padStart(8)} | ` +
      `${'Median'.padStart(8)} | ` +
      `${'Min'.padStart(8)} | ` +
      `${'Max'.padStart(8)} | ` +
      `${'Type'.padStart(10)}`
  );
  console.log('-'.repeat(90));

  for (const result of results) {
    if (result) {
      const hmrType = result.hmrType || 'mixed';
      console.log(
        `${result.name.padEnd(35)} | ` +
          `${(result.avgTime + 'ms').padStart(8)} | ` +
          `${(result.medianTime + 'ms').padStart(8)} | ` +
          `${(result.minTime + 'ms').padStart(8)} | ` +
          `${(result.maxTime + 'ms').padStart(8)} | ` +
          `${hmrType.padStart(10)}`
      );
    }
  }

  console.log('-'.repeat(90));

  const validResults = results.filter(r => r !== null && r !== undefined);
  if (validResults.length > 1) {
    const fastest = validResults.reduce((min, r) => (r.avgTime < min.avgTime ? r : min));
    const slowest = validResults.reduce((max, r) => (r.avgTime > max.avgTime ? r : max));

    console.log('\nSummary:');
    console.log(`  Fastest HMR: ${fastest.name} (${fastest.avgTime}ms avg)`);
    console.log(`  Slowest HMR: ${slowest.name} (${slowest.avgTime}ms avg)`);
    console.log(
      `  Difference: ${slowest.avgTime - fastest.avgTime}ms (${((slowest.avgTime / fastest.avgTime - 1) * 100).toFixed(1)}%)`
    );
  }

  console.log('\n' + '='.repeat(90));
}

async function cleanup() {
  console.log('\n[CLEANUP] Cleaning up...');
  await restoreOriginalFiles();

  try {
    await fs.rm(PLAYGROUND_DIR, { recursive: true, force: true });
    console.log('[OK] Cleanup complete');
  } catch (err) {
    console.warn('[WARN] Cleanup warning:', err.message);
  }
}

async function main() {
  console.log('='.repeat(78));
  console.log('     Click UI - HMR (Hot Module Replacement) Benchmark');
  console.log('     Tests reload speed when modifying source files');
  console.log('='.repeat(78));
  console.log(
    '\n[WARN] This benchmark will temporarily modify source files in src/components/'
  );
  console.log('   Original content will be automatically restored after testing.\n');

  // Check for root-level symlink
  const rootSymlink = path.join(ROOT_DIR, 'node_modules', '@clickhouse', 'click-ui');
  try {
    await fs.access(rootSymlink);
    console.log('[CHECK] Root-level symlink exists: node_modules/@clickhouse/click-ui');
  } catch (err) {
    console.log('[WARN] Root-level symlink not found: node_modules/@clickhouse/click-ui');
    console.log(
      '[INFO] Run "npm install" or "yarn install" to create the symlink via the prepare script.\n'
    );
  }

  try {
    await setupPlayground();
    await installDependencies();
    // Note: Using Vite resolve aliases instead of symlinks for package exports

    const results = [];

    for (const config of configs) {
      const result = await runBenchmarkWithServer(config);
      results.push(result);

      if (config !== configs[configs.length - 1]) {
        await new Promise(r => setTimeout(r, 2000));
      }
    }

    printResults(results);
  } catch (error) {
    console.error('\n[ERROR] Benchmark failed:', error.message);
    console.error(error.stack);
    process.exit(1);
  } finally {
    await cleanup();
  }
}

process.on('SIGINT', async () => {
  console.log('\n\n[WARN] Interrupted, cleaning up...');
  await cleanup();
  process.exit(0);
});

process.on('SIGTERM', async () => {
  console.log('\n\n[WARN] Terminated, cleaning up...');
  await cleanup();
  process.exit(0);
});

main();
