  const packageJson = {
    name: 'click-ui-hmr-benchmark',
    private: true,
    type: 'module',
    scripts: { dev: 'vite --port 5174 --host' },
    dependencies: {
      react: '^18.3.1',
      'react-dom': '^18.3.1',
      'styled-components': '^6.1.11',
      dayjs: '^1.11.19',
    },
    devDependencies: {
      '@types/react': '^18.3.1',
      '@types/react-dom': '^18.3.1',
      '@types/styled-components': '^5.1.34',
      '@vitejs/plugin-react': '^5.1.2',
      typescript: '^5.5.3',
      vite: '^7.3.0',
      'vite-tsconfig-paths': '^6.0.5',
    },
  };

  await fs.writeFile(
    path.join(PLAYGROUND_DIR, 'package.json'),
    JSON.stringify(packageJson, null, 2)
  );

  const indexHtml = `<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Click UI HMR Benchmark</title>
  </head>
  <body>
    <div id="root"></div>
    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
`;
  await fs.writeFile(path.join(PLAYGROUND_DIR, 'index.html'), indexHtml);

  const tsConfig = {
    compilerOptions: {
      target: 'ES2020',
      useDefineForClassFields: true,
      lib: ['ES2020', 'DOM', 'DOM.Iterable'],
      module: 'ESNext',
      skipLibCheck: true,
      moduleResolution: 'bundler',
      allowImportingTsExtensions: true,
      resolveJsonModule: true,
      isolatedModules: true,
      noEmit: true,
      jsx: 'react-jsx',
      strict: true,
      noUnusedLocals: true,
      noUnusedParameters: true,
      noFallthroughCasesInSwitch: true,
      baseUrl: '.',
      paths: {
        '@/*': [`${PLAYGROUND_PATH_TO_ROOT}/src/*`],
        '@/components': [`${PLAYGROUND_PATH_TO_ROOT}/src/components`],
        '@/index': [`${PLAYGROUND_PATH_TO_ROOT}/src/index.ts`],
      },
    },
    include: ['src/**/*', `${PLAYGROUND_PATH_TO_ROOT}/src/**/*`],
