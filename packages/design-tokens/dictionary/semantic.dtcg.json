          "$value": "{color.gray.100}",
          "$extensions": {
            "mode": {
              "light": "{color.gray.100}",
              "dark": "{color.charcoal.surface.250}"
            }
          },
          "$description": "Muted stroke utility — global, sidebar hover base"
        }
