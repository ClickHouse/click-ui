        "default": {
          "$type": "color",
          "$value": "{color.gray.400}",
          "$extensions": {
            "mode": {
              "light": "{color.gray.400}",
              "dark": "{color.charcoal.text.400}"
            }
          },
          "$description": "Solid default bg — badge.solid"
