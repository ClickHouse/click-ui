  "utility": {
    "color": {
      "shadow": {
        "default": {
          "$type": "color",
          "$value": "{color.shadow.default}",
          "$extensions": {
            "mode": {
              "light": "{color.shadow.default}",
              "dark": "{color.shadow.opacity.30}"
            }
          },
          "$description": "Box shadow colour"
        }
      },
      "scrim": {
        "dialog": {
          "$type": "color",
          "$value": "{color.scrim.heavy}",
          "$extensions": {
            "mode": {
              "light": "{color.scrim.heavy}",
              "dark": "{color.shadow.opacity.80}"
