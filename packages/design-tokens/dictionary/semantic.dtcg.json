        "neutral": {
          "subtle": {
            "$type": "color",
            "$value": "{color.neutral.opacity.10}",
            "$extensions": {
              "mode": {
                "light": "{color.neutral.opacity.10}",
                "dark": "{color.neutral.opacity.15}"
              }
            },
            "$description": "Neutral tinted bg — alert, badge"
          }
        }
      },
      "select": {
