          "disabled": {
            "$type": "color",
            "$value": "{color.gray.300}",
            "$extensions": {
              "mode": {
                "light": "{color.gray.300}",
                "dark": "{color.charcoal.surface.300}"
              }
            },
            "$description": "Secondary button disabled"
