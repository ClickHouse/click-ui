    },
    "lg": {
      "$type": "dimension",
      "$value": "{space.200}",
      "$description": "Large spacing — 16px, card padding, section gaps"
    },
    "xl": {
      "$type": "dimension",
      "$value": "{space.300}",
      "$description": "Extra-large spacing — 24px, container gaps, generous padding"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "{space.400}",
      "$description": "2x large spacing — 32px, layout gaps, spacious sections"
    },
    "3xl": {
      "$type": "dimension",
      "$value": "{space.600}",
      "$description": "3x large spacing — 48px, major layout gaps, section breaks"
