          "default": {
            "$type": "color",
            "$value": "{color.transparent}",
            "$extensions": {
              "mode": {
                "light": "{color.transparent}",
                "dark": "{color.transparent}"
              }
            },
            "$description": "Secondary button (ghost/outline) default — transparent"
          },
          "hover": {
            "$type": "color",
            "$value": "{color.gray.50}",
            "$extensions": {
              "mode": {
                "light": "{color.gray.50}",
                "dark": "{color.charcoal.surface.200}"
              }
            },
            "$description": "Secondary button hover — subtle tint"
