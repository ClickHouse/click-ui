        "tooltip": {
          "$type": "color",
          "$value": "{color.scrim.tooltip}",
          "$extensions": {
            "mode": {
              "light": "{color.scrim.tooltip}",
              "dark": "{color.shadow.opacity.90}"
            }
          },
          "$description": "Tooltip dark bg"
