        "warning": {
          "$type": "color",
          "$value": "{color.orange.100}",
          "$extensions": {
            "mode": {
              "light": "{color.orange.100}",
              "dark": "{color.orange.200}"
            }
          },
          "$description": "Warning bordered elements"
        },
        "neutral": {
          "$type": "color",
          "$value": "{color.neutral.100}",
