          "hover": {
            "$type": "color",
            "$value": "{color.blue.600}",
            "$extensions": {
              "mode": {
                "light": "{color.blue.600}",
                "dark": "{color.blue.lighter}"
              }
            },
            "$description": "Link / empty button hover"
          }
