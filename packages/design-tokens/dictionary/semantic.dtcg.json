        },
        "info": {
          "subtle": {
            "$type": "color",
            "$value": "{color.blue.300}",
            "$extensions": {
              "mode": {
                "light": "{color.blue.300}",
                "dark": "{color.blue.400}"
              }
            },
            "$description": "Info tinted bg — alert, badge, iconButton"
