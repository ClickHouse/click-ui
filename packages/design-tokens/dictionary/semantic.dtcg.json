        "$value": "{color.gray.300}",
        "$extensions": {
          "org.terrazzo.resolver": {
            "modes": {
              "light": "{color.gray.300}",
              "dark": "{color.gray.1150}"
            }
          }
        },
        "$description": "Disabled background across all components"
