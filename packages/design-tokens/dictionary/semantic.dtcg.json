        "$type": "color",
        "$value": "{color.gray.50}",
        "$extensions": {
          "org.terrazzo.resolver": {
            "modes": {
              "light": "{color.gray.50}",
              "dark": "{color.gray.1100}"
            }
          }
        },
        "$description": "Hover surface, muted card, secondary bg"
      },
      "muted": {
