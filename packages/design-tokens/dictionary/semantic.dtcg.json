        },
        "warning": {
          "subtle": {
            "$type": "color",
            "$value": "{color.orange.300}",
            "$extensions": {
              "mode": {
                "light": "{color.orange.300}",
                "dark": "{color.orange.400}"
              }
            },
            "$description": "Warning tinted bg — alert, badge"
