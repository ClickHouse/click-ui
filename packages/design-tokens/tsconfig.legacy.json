{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/legacy",
    "rootDir": "./legacy",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["legacy/**/*"],
  "exclude": ["node_modules", "dist"]
}
