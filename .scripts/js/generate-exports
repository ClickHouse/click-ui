#!/usr/bin/env node

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import ts from 'typescript';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const rootDir = path.resolve(__dirname, '..');
const indexPath = path.join(rootDir, 'src/index.ts');
const packageJsonPath = path.join(rootDir, 'package.json');

const extractComponentNames = (filePath) => {
  const sourceCode = fs.readFileSync(filePath, 'utf-8');
  const sourceFile = ts.createSourceFile(
    filePath,
    sourceCode,
    ts.ScriptTarget.Latest,
    true
  );

  const componentNames = new Set();
  const componentsPrefix = './components/';

  const visit = (node) => {
    if (ts.isExportDeclaration(node) && node.moduleSpecifier) {
      const modulePath = node.moduleSpecifier.getText(sourceFile).slice(1, -1);

      if (modulePath.startsWith(componentsPrefix)) {
        const pathAfterComponents = modulePath.slice(componentsPrefix.length);
        const componentFolder = pathAfterComponents.split('/')[0];
        componentNames.add(componentFolder);
      }
    }
    ts.forEachChild(node, visit);
  };

  visit(sourceFile);
  return Array.from(componentNames).sort();
};

try {
  const packageJson = JSON.parse(fs.readFileSync(packageJsonPath, 'utf-8'));

  const exports = {
    '.': {
      types: './dist/types/index.d.ts',
      import: './dist/esm/index.js',
      require: './dist/cjs/index.cjs',
    },
  };

  const componentsDir = path.join(rootDir, 'src/components');
  const candidateComponents = extractComponentNames(indexPath);

  const components = candidateComponents.filter(component => {
    const indexFile = path.join(componentsDir, component, 'index.ts');
    return fs.existsSync(indexFile);
  });

  const componentsSet = new Set(components);
  const skipped = candidateComponents.filter(c => !componentsSet.has(c));

  for (const component of components) {
    exports[`./${component}`] = {
      types: `./dist/types/components/${component}/index.d.ts`,
      import: `./dist/esm/components/${component}/index.js`,
      require: `./dist/cjs/components/${component}/index.cjs`,
    };
  }

  packageJson.exports = exports;

  fs.writeFileSync(packageJsonPath, JSON.stringify(packageJson, null, 2) + '\n');

  console.log(`\n🤖 Generated exports for ${components.length} components:\n`);

  components.forEach(name => console.log(`✔ ${name}`));

  if (skipped.length > 0) {
    console.log(`\n⚠ Skipped ${skipped.length} paths (no index.ts barrel export):\n`);
    skipped.forEach(name => console.log(`  - ${name}`));
  }

  process.exit(0);
} catch (err) {
  console.error('\n👹 Oops! Failed to generate exports:\n');

  console.error(err.message);
  process.exit(1);
}
