#!/usr/bin/env node

import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const rootDir = path.resolve(__dirname, '..');
const nodeModulesDir = path.join(rootDir, 'node_modules');
const clickhouseDir = path.join(nodeModulesDir, '@clickhouse');
const linkTarget = path.join(clickhouseDir, 'click-ui');

if (process.env.CI || !fs.existsSync(nodeModulesDir)) {
  console.log(
    '[package-linker] Skipping symlink creation (CI environment or no node_modules)'
  );
  process.exit(0);
}

if (!fs.existsSync(clickhouseDir)) {
  fs.mkdirSync(clickhouseDir, { recursive: true });
}

try {
  fs.unlinkSync(linkTarget);
} catch (err) {}

try {
  fs.symlinkSync(rootDir, linkTarget, 'dir');
  console.log(`[package-linker] Created symlink: ${linkTarget} -> ${rootDir}`);
} catch (err) {
  console.error(`[package-linker] Failed to create symlink: ${err.message}`);
  process.exit(1);
}
