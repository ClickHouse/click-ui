#!/usr/bin/env node

/**
 * CSS Modules Preprocessing Script
 * 
 * This script runs BEFORE the Vite build to process all .module.css files:
 * 1. Transforms CSS class names (adds hashes)
 * 2. Generates .css files with hashed classes in .temp/ directory
 * 3. Generates .module.json files with class mappings in .temp/ directory
 * 
 * The Vite build then uses these pre-generated files instead of processing
 * CSS modules itself.
 */

import fs from 'fs/promises';
import path from 'path';
import { fileURLToPath } from 'url';
import postcss from 'postcss';
import postcssModules from 'postcss-modules';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);
const rootDir = path.resolve(__dirname, '../..');
const srcDir = path.join(rootDir, 'src');
const tempDir = path.join(rootDir, '.temp', 'css-modules');

// Hash pattern matching Vite's default behavior
const generateScopedName = '[hash:base64:8]_[local]';

async function findFiles(dir, pattern) {
  const results = [];

  async function walk(currentDir) {
    const entries = await fs.readdir(currentDir, { withFileTypes: true });

    for (const entry of entries) {
      const fullPath = path.join(currentDir, entry.name);

      if (entry.isDirectory()) {
        await walk(fullPath);
      } else if (entry.isFile() && pattern.test(entry.name)) {
        results.push(fullPath);
      }
    }
  }

  await walk(dir);
  return results;
}

async function processCssModule(filePath) {
  const css = await fs.readFile(filePath, 'utf-8');
  const relativePath = path.relative(srcDir, filePath);
  
  let classMapping = {};
  
  const result = await postcss([
    postcssModules({
      generateScopedName,
      getJSON: (cssFileName, json) => {
        classMapping = json;
      }
    })
  ]).process(css, { from: filePath });
  
  // Generate output paths in temp directory
  const tempPath = path.join(tempDir, relativePath.replace('.module.css', ''));
  const cssOutputPath = `${tempPath}.css`;
  const jsonOutputPath = `${tempPath}.module.json`;
  
  // Ensure temp directory exists
  await fs.mkdir(path.dirname(tempPath), { recursive: true });
  
  // Write processed CSS (with hashed classes)
  await fs.writeFile(cssOutputPath, result.css);
  
  // Write class mapping JSON
  await fs.writeFile(jsonOutputPath, JSON.stringify(classMapping, null, 2));
  
  console.log(`✓ Processed: ${relativePath}`);
  console.log(`  → .temp/css-modules/${path.relative(srcDir, tempPath)}.css`);
  console.log(`  → .temp/css-modules/${path.relative(srcDir, tempPath)}.module.json`);
  
  return {
    source: filePath,
    cssOutput: cssOutputPath,
    jsonOutput: jsonOutputPath,
    relativePath: relativePath.replace('.module.css', ''),
    mappings: classMapping
  };
}

async function main() {
  console.log('\n🔧 Pre-processing CSS Modules...\n');
  
  try {
    // Clean up temp directory first
    try {
      await fs.rm(tempDir, { recursive: true, force: true });
    } catch {
      // Directory might not exist
    }
    
    // Find all .module.css files
    const files = await findFiles(srcDir, /\.module\.css$/);
    
    if (files.length === 0) {
      console.log('ℹ️  No .module.css files found\n');
      return;
    }
    
    console.log(`Found ${files.length} CSS module file(s)\n`);
    
    const results = [];
    for (const file of files) {
      const result = await processCssModule(file);
      results.push(result);
    }
    
    console.log('\n✅ CSS Modules pre-processing complete!\n');
    
    // Summary
    const totalClasses = results.reduce((sum, r) => sum + Object.keys(r.mappings).length, 0);
    console.log(`Summary: ${files.length} file(s), ${totalClasses} class(es) processed`);
    console.log(`Location: .temp/css-modules/\n`);
    
  } catch (error) {
    console.error('\n❌ Error processing CSS Modules:\n');
    console.error(error.message);
    process.exit(1);
  }
}

main();
